generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(cuid())
  name                     String
  email                    String                 @unique
  phone                    String?
  passwordHash             String
  role                     String                 @default("USER")
  status                   String                 @default("ACTIVE")
  avatarUrl                String?
  emailNotifications       Boolean                @default(true)
  emailVerified            Boolean                @default(false)
  verificationOtp          String?
  verificationOtpExpiry    DateTime?
  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  deletedAt                DateTime?
  auditLogs                AuditLog[]
  chatbotLogs              ChatbotLog[]
  contactMessages          ContactMessage[]
  approvedDisbursements    Disbursement[]         @relation("ApprovedBy")
  donations                Donation[]
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  generatedReports         Report[]
  reviewedVolunteers           VolunteerApplication[]    @relation("ReviewedBy")
  reviewedHelpRequests         HelpRequest[]             @relation("ReviewedHelpRequests")
  volunteerApplications        VolunteerApplication[]    @relation("VolunteerApplicant")
  performedVolunteerLogs       VolunteerProcessLog[]     @relation("VolunteerProcessLogActor")
  performedHelpRequestLogs     HelpRequestProcessLog[]   @relation("HelpRequestProcessLogActor")
  helpRequestApplications      HelpRequest[]             @relation("HelpRequestApplicant")
  assignedHelpRequests         HelpRequest[]             @relation("AssignedResearcher")
  fieldReports                 FieldReport[]             @relation("ResearcherFieldReports")
  donationOtps                 DonationOtp[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Program {
  id            String        @id @default(cuid())
  name          String
  icon          String?
  color         String?
  description   String?
  status        String        @default("ACTIVE")
  isHighlighted Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  imageUrl      String?
  beneficiaries Beneficiary[]
  projects      Project[]

  @@map("programs")
}

model Project {
  id             String        @id @default(cuid())
  programId      String
  title          String
  description    String?
  goal           Decimal
  raised         Decimal       @default(0)
  donorsCount    Int           @default(0)
  imageUrl       String?
  location       String?
  status         String        @default("ACTIVE")
  featured       Boolean       @default(false)
  isHighlighted  Boolean       @default(false)
  endDate        DateTime?
  donationAmount Decimal?
  amountConfig   String        @default("FLEXIBLE")
  sharePrice     Float?
  totalRaised    Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  donations      Donation[]
  program        Program       @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([status])
  @@map("projects")
}

model Donation {
  id                 String              @id @default(cuid())
  userId             String
  projectId          String?
  campaignId         String?
  amount             Float
  type               String              @default("GENERAL")
  paymentMethod      String
  status             String              @default("PENDING")
  source             String              @default("ONLINE")
  isAnonymous        Boolean             @default(false)
  isRecurring        Boolean             @default(false)
  recurringFrequency String?
  fullName           String?
  phone              String?
  email              String?
  notes              String?
  receiptNumber      String              @unique
  idempotencyKey     String?             @unique
  internalReference  String              @unique @default(cuid())
  walletPhone        String?
  simulatedPaymentId String?
  transactionId      String?
  collectionAddress  String?
  refundReason       String?
  paidAt             DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  project            Project?            @relation(fields: [projectId], references: [id])
  campaign           Campaign?           @relation(fields: [campaignId], references: [id])
  user               User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

model Beneficiary {
  id            String          @id @default(cuid())
  name          String
  type          String @default("FAMILY")
  phone         String?
  nationalId    String?         @unique
  governorate   String?
  address       String?
  notes         String?
  programId     String?
  status        String        @default("PENDING")
  monthlyAid    Decimal? 
  membersCount  Int?
  startDate     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  program       Program?        @relation(fields: [programId], references: [id])
  disbursements Disbursement[]

  @@index([status])
  @@index([programId])
  @@map("beneficiaries")
}

model Disbursement {
  id            String             @id @default(cuid())
  beneficiaryId String
  amount        Decimal     
  type          String
  status        String              @default("PENDING")
  approvedById  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  approvedBy    User?              @relation("ApprovedBy", fields: [approvedById], references: [id])
  beneficiary   Beneficiary        @relation(fields: [beneficiaryId], references: [id])

  @@index([beneficiaryId])
  @@index([status])
  @@map("disbursements")
}

model Report {
  id            String     @id @default(cuid())
  title         String
  type          String
  period        String
  fileUrl       String?
  generatedById String
  createdAt     DateTime   @default(now())
  generatedBy   User       @relation(fields: [generatedById], references: [id])

  @@map("reports")
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String
  isRead     Boolean  @default(false)
  userId     String?
  isForAdmin Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model VolunteerApplication {
  id                String             @id @default(cuid())
  name              String
  email             String
  phone             String
  area              String
  message           String?
  status            String             @default("PENDING")
  reviewedById      String?
  reviewedAt        DateTime?
  rejectionReason   String?
  adminNotes        String?
  nextSteps         String?
  cvFile            String?
  cvUrl             String?
  userId            String?
  contactMethod     String?
  contactedAt       DateTime?
  applicantResponse String?
  respondedAt       DateTime?
  responseNotes     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  reviewedBy        User?              @relation("ReviewedBy", fields: [reviewedById], references: [id])
  user              User?              @relation("VolunteerApplicant", fields: [userId], references: [id])
  processLogs       VolunteerProcessLog[]

  @@index([userId])
  @@map("volunteer_applications")
}

model VolunteerProcessLog {
  id            String             @id @default(cuid())
  volunteerId   String
  volunteer     VolunteerApplication @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  action        String
  performedById String?
  performedBy   User?              @relation("VolunteerProcessLogActor", fields: [performedById], references: [id])
  details       String?
  createdAt     DateTime           @default(now())

  @@index([volunteerId])
  @@map("volunteer_process_logs")
}

model HelpRequestProcessLog {
  id            String      @id @default(cuid())
  helpRequestId String
  helpRequest   HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  action        String
  performedById String?
  performedBy   User?       @relation("HelpRequestProcessLogActor", fields: [performedById], references: [id])
  details       String?
  createdAt     DateTime    @default(now())

  @@index([helpRequestId])
  @@map("help_request_process_logs")
}

model ContactMessage {
  id            String        @id @default(cuid())
  userId        String?
  name          String
  email         String
  phone         String?
  subject       String
  message       String
  contactMethod String?
  status        String        @default("NEW")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])

  @@map("contact_messages")
}

model HelpRequest {
  id                   String                  @id @default(cuid())
  source               String                  @default("ONLINE")
  status               String                  @default("NEW")
  
  // Basic info (for online requests or general)
  name                 String?
  email                String?
  phone                String?
  requestType          String
  description          String
  
  // Offline fallback fields
  offlineName          String?
  offlinePhone         String?
  offlineNationalId    String?

  // Relations
  userId               String?
  user                 User?                   @relation("HelpRequestApplicant", fields: [userId], references: [id])
  
  assignedResearcherId String?
  assignedResearcher   User?                   @relation("AssignedResearcher", fields: [assignedResearcherId], references: [id])

  reviewedById         String?
  reviewedBy           User?                   @relation("ReviewedHelpRequests", fields: [reviewedById], references: [id])
  reviewedAt           DateTime?

  aidType              String?
  aidAmount            Decimal?
  aidQuantity          String?
  distributionStatus   String?
  adminNotes           String?
  rejectionReason      String?

  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  fieldReports         FieldReport[]
  documents            RequestDocument[]
  processLogs          HelpRequestProcessLog[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@map("help_requests")
}

model FieldReport {
  id               String              @id @default(cuid())
  helpRequestId    String
  helpRequest      HelpRequest         @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  researcherId     String
  researcher       User                @relation("ResearcherFieldReports", fields: [researcherId], references: [id])
  visitDate        DateTime
  housingCondition String
  incomeEstimate   Decimal
  researcherNotes  String
  recommendation   String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([helpRequestId])
  @@index([researcherId])
  @@map("field_reports")
}

model RequestDocument {
  id            String         @id @default(cuid())
  helpRequestId String
  helpRequest   HelpRequest    @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  docType       String
  fileUrl       String
  createdAt     DateTime       @default(now())

  @@index([helpRequestId])
  @@map("request_documents")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorRole String
  action    String
  entity    String
  entityId  String
  payload   String?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Reconciliation {
  id                       String   @id @default(cuid())
  periodStart              DateTime
  periodEnd                DateTime
  totalSystemAmount        Decimal
  totalSuccessfulDonations Int
  createdAt                DateTime @default(now())

  @@map("reconciliations")
}

model OrgSettings {
  id                   String   @id @default("singleton")
  name                 String   @default("جمعية نور الخيرية")
  email                String   @default("info@nour-charity.org")
  phone                String   @default("+20 2 1234 5678")
  address              String   @default("القاهرة، مصر")
  language             String   @default("ar")
  timezone             String   @default("Africa/Cairo")
  currency             String   @default("EGP")
  notifyNewDonation    Boolean  @default(true)
  notifyDisbursement   Boolean  @default(true)
  notifyNewBeneficiary Boolean  @default(false)
  notifyWeeklyReport   Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("org_settings")
}

model ChatbotLog {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  reply     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chatbot_logs")
}

model Campaign {
  id           String         @id @default(cuid())
  title        String
  description  String?
  imageUrl     String?
  goal         Decimal 
  raised       Decimal        @default(0)
  donorsCount  Int            @default(0)
  status       String         @default("ACTIVE")
  startDate    DateTime       @default(now())
  endDate      DateTime?
  featured     Boolean        @default(false)
  category     String?
  amountConfig String         @default("FLEXIBLE")
  sharePrice   Float?
  totalRaised  Float          @default(0)
  donations    Donation[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([status])
  @@index([endDate])
  @@map("campaigns")
}


model AuditReport {
  id        String   @id @default(cuid())
  year      String
  firm      String
  status    String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audit_reports")
}

model DonationOtp {
  id                String   @id @default(cuid())
  userId            String
  otpCode           String
  expiresAt         DateTime
  amount            Float
  projectId         String?
  campaignId        String?
  paymentMethod     String
  collectionAddress String?
  fawryCode         String?
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("donation_otps")
}
