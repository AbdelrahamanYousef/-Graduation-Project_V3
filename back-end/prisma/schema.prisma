generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum DonationType {
  SADAQAH
  ZAKAT
  ORPHAN_SPONSORSHIP
  SADAQAH_JARIYAH
  GENERAL
}

enum PaymentMethod {
  CARD
  VODAFONE_CASH
  ORANGE_CASH
  INSTAPAY
  FAWRY
  BANK_TRANSFER
}

enum DisbursementStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum BeneficiaryType {
  FAMILY
  INDIVIDUAL
  INSTITUTION
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PENDING
}

enum ReportType {
  DONATIONS
  BENEFICIARIES
  PROJECTS
  FINANCE
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum VolunteerArea {
  MEDICAL
  EDUCATION
  COMMUNITY
  TECH
  ADMIN
  FIELD
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

// ─── MODELS ─────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  passwordHash String
  role         UserRole     @default(USER)
  status       EntityStatus @default(ACTIVE)
  avatarUrl    String?

  emailVerified       Boolean    @default(false)
  verificationOtp     String?
  verificationOtpExpiry DateTime?

  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?

  approvedDisbursements Disbursement[]         @relation("ApprovedBy")
  generatedReports      Report[]
  notifications         Notification[]
  donations             Donation[]
  reviewedVolunteers    VolunteerApplication[] @relation("ReviewedBy")
  auditLogs             AuditLog[]
  refreshTokens         RefreshToken[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Program {
  id          String       @id @default(cuid())
  name        String
  icon        String?
  color       String?
  description String?
  status      EntityStatus @default(ACTIVE)

  projects      Project[]
  beneficiaries Beneficiary[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("programs")
}

model Project {
  id             String        @id @default(cuid())
  programId      String
  program        Program       @relation(fields: [programId], references: [id])
  title          String
  description    String?
  goal           Decimal       @db.Decimal(12, 2)
  raised         Decimal       @default(0) @db.Decimal(12, 2)
  donorsCount    Int           @default(0)
  imageUrl       String?
  location       String?
  status         ProjectStatus @default(ACTIVE)
  featured       Boolean       @default(false)
  endDate        DateTime?
  donationAmount Decimal?      @db.Decimal(12, 2)

  donations Donation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([programId])
  @@index([status])
  @@map("projects")
}

model Donation {
  id                 String              @id @default(cuid())
  userId             String?
  user               User?               @relation(fields: [userId], references: [id])
  projectId          String?
  project            Project?            @relation(fields: [projectId], references: [id])
  amount             Decimal             @db.Decimal(12, 2)
  type               DonationType        @default(GENERAL)
  paymentMethod      PaymentMethod
  status             DonationStatus      @default(PENDING)
  isAnonymous        Boolean             @default(false)
  isRecurring        Boolean             @default(false)
  recurringFrequency RecurringFrequency?
  fullName           String?
  phone              String?
  email              String?
  notes              String?
  receiptNumber      String              @unique
  idempotencyKey     String?             @unique
  internalReference  String              @unique @default(cuid())
  walletPhone        String?
  simulatedPaymentId String?
  paidAt             DateTime?
  refundReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

model Beneficiary {
  id           String          @id @default(cuid())
  name         String
  type         BeneficiaryType @default(FAMILY)
  phone        String?
  nationalId   String?         @unique
  governorate  String?
  address      String?
  notes        String?
  programId    String?
  program      Program?        @relation(fields: [programId], references: [id])
  status       EntityStatus    @default(PENDING)
  monthlyAid   Decimal?        @db.Decimal(10, 2)
  membersCount Int?
  startDate    DateTime?

  disbursements Disbursement[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([programId])
  @@map("beneficiaries")
}

model Disbursement {
  id            String             @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary        @relation(fields: [beneficiaryId], references: [id])
  amount        Decimal            @db.Decimal(12, 2)
  type          String
  status        DisbursementStatus @default(PENDING)
  approvedById  String?
  approvedBy    User?              @relation("ApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([beneficiaryId])
  @@index([status])
  @@map("disbursements")
}

model Report {
  id            String     @id @default(cuid())
  title         String
  type          ReportType
  period        String
  fileUrl       String?
  generatedById String
  generatedBy   User       @relation(fields: [generatedById], references: [id])

  createdAt DateTime @default(now())

  @@map("reports")
}

model Notification {
  id      String  @id @default(cuid())
  title   String
  message String
  type    String
  isRead  Boolean @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model VolunteerApplication {
  id              String          @id @default(cuid())
  name            String
  email           String
  phone           String
  area            VolunteerArea
  message         String?
  status          VolunteerStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?           @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("volunteer_applications")
}

model ContactMessage {
  id      String        @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String
  status  ContactStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  actorRole String
  action    String
  entity    String
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Reconciliation {
  id                       String   @id @default(cuid())
  periodStart              DateTime
  periodEnd                DateTime
  totalSystemAmount        Decimal  @db.Decimal(12, 2)
  totalSuccessfulDonations Int
  createdAt                DateTime @default(now())

  @@map("reconciliations")
}

model OrgSettings {
  id       String @id @default("singleton")
  name     String @default("جمعية نور الخيرية")
  email    String @default("info@nour-charity.org")
  phone    String @default("+20 2 1234 5678")
  address  String @default("القاهرة، مصر")
  language String @default("ar")
  timezone String @default("Africa/Cairo")
  currency String @default("EGP")

  notifyNewDonation    Boolean @default(true)
  notifyDisbursement   Boolean @default(true)
  notifyNewBeneficiary Boolean @default(false)
  notifyWeeklyReport   Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("org_settings")
}
