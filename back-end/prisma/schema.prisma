generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                  @id @default(cuid())
  name                     String
  email                    String                  @unique
  phone                    String?
  passwordHash             String
  avatarUrl                String?
  emailVerified            Boolean                 @default(false)
  verificationOtp          String?
  verificationOtpExpiry    DateTime?
  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  deletedAt                DateTime?
  emailNotifications       Boolean                 @default(true)
  role                     String                  @default("USER")
  status                   String                  @default("ACTIVE")
  auditLogs                AuditLog[]
  chatbotLogs              ChatbotLog[]
  contactMessages          ContactMessage[]
  approvedDisbursements    Disbursement[]          @relation("ApprovedBy")
  donationOtps             DonationOtp[]
  donations                Donation[]
  fieldReports             FieldReport[]           @relation("ResearcherFieldReports")
  performedHelpRequestLogs HelpRequestProcessLog[] @relation("HelpRequestProcessLogActor")
  assignedHelpRequests     HelpRequest[]           @relation("AssignedResearcher")
  reviewedHelpRequests     HelpRequest[]           @relation("ReviewedHelpRequests")
  helpRequestApplications  HelpRequest[]           @relation("HelpRequestApplicant")
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  generatedReports         Report[]
  reviewedVolunteers       VolunteerApplication[]  @relation("ReviewedBy")
  volunteerApplications    VolunteerApplication[]  @relation("VolunteerApplicant")
  performedVolunteerLogs   VolunteerProcessLog[]   @relation("VolunteerProcessLogActor")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Program {
  id            String        @id @default(cuid())
  name          String
  icon          String?
  color         String?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  imageUrl      String?
  isHighlighted Boolean       @default(false)
  status        String        @default("ACTIVE")
  beneficiaries Beneficiary[]
  projects      Project[]

  @@map("programs")
}

model Project {
  id             String     @id @default(cuid())
  programId      String
  title          String
  description    String?
  goal           Decimal
  raised         Decimal    @default(0)
  donorsCount    Int        @default(0)
  imageUrl       String?
  location       String?
  featured       Boolean    @default(false)
  endDate        DateTime?
  donationAmount Decimal?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  isHighlighted  Boolean    @default(false)
  amountConfig   String     @default("FLEXIBLE")
  sharePrice     Float?
  totalRaised    Float      @default(0)
  status         String     @default("ACTIVE")
  donations      Donation[]
  program        Program    @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([status])
  @@map("projects")
}

model Donation {
  id                 String    @id @default(cuid())
  userId             String
  projectId          String?
  amount             Float
  isAnonymous        Boolean   @default(false)
  isRecurring        Boolean   @default(false)
  fullName           String?
  phone              String?
  email              String?
  notes              String?
  receiptNumber      String    @unique
  idempotencyKey     String?   @unique
  internalReference  String    @unique @default(cuid())
  walletPhone        String?
  simulatedPaymentId String?
  paidAt             DateTime?
  refundReason       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  campaignId         String?
  collectionAddress  String?
  source             String    @default("ONLINE")
  transactionId      String?
  type               String    @default("GENERAL")
  paymentMethod      String
  status             String    @default("PENDING")
  recurringFrequency String?
  campaign           Campaign? @relation(fields: [campaignId], references: [id])
  project            Project?  @relation(fields: [projectId], references: [id])
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

model Beneficiary {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  nationalId    String?        @unique
  governorate   String?
  address       String?
  notes         String?
  programId     String?
  monthlyAid    Decimal?
  membersCount  Int?
  startDate     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  type          String         @default("FAMILY")
  status        String         @default("PENDING")
  program       Program?       @relation(fields: [programId], references: [id])
  disbursements Disbursement[]

  @@index([status])
  @@index([programId])
  @@map("beneficiaries")
}

model Disbursement {
  id            String      @id @default(cuid())
  beneficiaryId String
  amount        Decimal
  type          String
  approvedById  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  status        String      @default("PENDING")
  approvedBy    User?       @relation("ApprovedBy", fields: [approvedById], references: [id])
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])

  @@index([beneficiaryId])
  @@index([status])
  @@map("disbursements")
}

model Report {
  id            String   @id @default(cuid())
  title         String
  period        String
  fileUrl       String?
  generatedById String
  createdAt     DateTime @default(now())
  type          String
  generatedBy   User     @relation(fields: [generatedById], references: [id])

  @@map("reports")
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String
  isRead     Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())
  isForAdmin Boolean  @default(false)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model VolunteerApplication {
  id                String                @id @default(cuid())
  name              String
  email             String
  phone             String
  message           String?
  reviewedById      String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  adminNotes        String?
  nextSteps         String?
  applicantResponse String?
  contactMethod     String?
  contactedAt       DateTime?
  cvFile            String?
  cvUrl             String?
  respondedAt       DateTime?
  responseNotes     String?
  userId            String?
  status            String                @default("PENDING")
  area              String
  reviewedBy        User?                 @relation("ReviewedBy", fields: [reviewedById], references: [id])
  user              User?                 @relation("VolunteerApplicant", fields: [userId], references: [id])
  processLogs       VolunteerProcessLog[]

  @@index([userId])
  @@map("volunteer_applications")
}

model VolunteerProcessLog {
  id            String               @id @default(cuid())
  volunteerId   String
  action        String
  performedById String?
  details       String?
  createdAt     DateTime             @default(now())
  performedBy   User?                @relation("VolunteerProcessLogActor", fields: [performedById], references: [id])
  volunteer     VolunteerApplication @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
  @@map("volunteer_process_logs")
}

model HelpRequestProcessLog {
  id            String      @id @default(cuid())
  helpRequestId String
  action        String
  performedById String?
  details       String?
  createdAt     DateTime    @default(now())
  helpRequest   HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  performedBy   User?       @relation("HelpRequestProcessLogActor", fields: [performedById], references: [id])

  @@index([helpRequestId])
  @@map("help_request_process_logs")
}

model ContactMessage {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  subject       String
  message       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contactMethod String?
  userId        String?
  status        String   @default("NEW")
  user          User?    @relation(fields: [userId], references: [id])

  @@map("contact_messages")
}

model HelpRequest {
  id                   String                  @id @default(cuid())
  source               String                  @default("ONLINE")
  status               String                  @default("NEW")
  name                 String?
  email                String?
  phone                String?
  requestType          String
  description          String
  offlineName          String?
  offlinePhone         String?
  offlineNationalId    String?
  userId               String?
  assignedResearcherId String?
  reviewedById         String?
  reviewedAt           DateTime?
  aidType              String?
  aidAmount            Decimal?
  aidQuantity          String?
  distributionStatus   String?
  adminNotes           String?
  rejectionReason      String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  fieldReports         FieldReport[]
  processLogs          HelpRequestProcessLog[]
  assignedResearcher   User?                   @relation("AssignedResearcher", fields: [assignedResearcherId], references: [id])
  reviewedBy           User?                   @relation("ReviewedHelpRequests", fields: [reviewedById], references: [id])
  user                 User?                   @relation("HelpRequestApplicant", fields: [userId], references: [id])
  documents            RequestDocument[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@map("help_requests")
}

model FieldReport {
  id               String      @id @default(cuid())
  helpRequestId    String
  researcherId     String
  visitDate        DateTime
  housingCondition String
  incomeEstimate   Decimal
  researcherNotes  String
  recommendation   String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  helpRequest      HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  researcher       User        @relation("ResearcherFieldReports", fields: [researcherId], references: [id])

  @@index([helpRequestId])
  @@index([researcherId])
  @@map("field_reports")
}

model RequestDocument {
  id            String      @id @default(cuid())
  helpRequestId String
  docType       String
  fileUrl       String
  createdAt     DateTime    @default(now())
  helpRequest   HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)

  @@index([helpRequestId])
  @@map("request_documents")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorRole String
  action    String
  entity    String
  entityId  String
  payload   String?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Reconciliation {
  id                       String   @id @default(cuid())
  periodStart              DateTime
  periodEnd                DateTime
  totalSystemAmount        Decimal
  totalSuccessfulDonations Int
  createdAt                DateTime @default(now())

  @@map("reconciliations")
}

model OrgSettings {
  id                   String   @id @default("singleton")
  name                 String   @default("جمعية نور الخيرية")
  email                String   @default("info@nour-charity.org")
  phone                String   @default("+20 2 1234 5678")
  address              String   @default("القاهرة، مصر")
  language             String   @default("ar")
  timezone             String   @default("Africa/Cairo")
  currency             String   @default("EGP")
  notifyNewDonation    Boolean  @default(true)
  notifyDisbursement   Boolean  @default(true)
  notifyNewBeneficiary Boolean  @default(false)
  notifyWeeklyReport   Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("org_settings")
}

model ChatbotLog {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  reply     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chatbot_logs")
}

model Campaign {
  id           String     @id @default(cuid())
  title        String
  description  String?
  imageUrl     String?
  goal         Decimal
  raised       Decimal    @default(0)
  donorsCount  Int        @default(0)
  startDate    DateTime   @default(now())
  endDate      DateTime?
  featured     Boolean    @default(false)
  category     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  amountConfig String     @default("FLEXIBLE")
  sharePrice   Float?
  totalRaised  Float      @default(0)
  status       String     @default("ACTIVE")
  donations    Donation[]

  @@index([status])
  @@index([endDate])
  @@map("campaigns")
}

model AuditReport {
  id        String   @id @default(cuid())
  year      String
  firm      String
  status    String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audit_reports")
}

model DonationOtp {
  id                String   @id @default(cuid())
  userId            String
  otpCode           String
  expiresAt         DateTime
  amount            Float
  projectId         String?
  campaignId        String?
  paymentMethod     String
  collectionAddress String?
  fawryCode         String?
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("donation_otps")
}
