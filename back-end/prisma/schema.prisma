generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(cuid())
  name                     String
  email                    String                 @unique
  phone                    String?
  passwordHash             String
  role                     UserRole               @default(USER)
  status                   EntityStatus           @default(ACTIVE)
  avatarUrl                String?
  emailVerified            Boolean                @default(false)
  verificationOtp          String?
  verificationOtpExpiry    DateTime?
  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  deletedAt                DateTime?
  auditLogs                AuditLog[]
  chatbotLogs              ChatbotLog[]
  approvedDisbursements    Disbursement[]         @relation("ApprovedBy")
  donations                Donation[]
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  generatedReports         Report[]
  reviewedVolunteers       VolunteerApplication[] @relation("ReviewedBy")
  reviewedSpecialRequests  SpecialRequest[]       @relation("ReviewedSpecialRequests")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Program {
  id            String        @id @default(cuid())
  name          String
  icon          String?
  color         String?
  description   String?
  status        EntityStatus  @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  imageUrl      String?
  beneficiaries Beneficiary[]
  projects      Project[]

  @@map("programs")
}

model Project {
  id             String        @id @default(cuid())
  programId      String
  title          String
  description    String?
  goal           Decimal       @db.Decimal(12, 2)
  raised         Decimal       @default(0) @db.Decimal(12, 2)
  donorsCount    Int           @default(0)
  imageUrl       String?
  location       String?
  status         ProjectStatus @default(ACTIVE)
  featured       Boolean       @default(false)
  endDate        DateTime?
  donationAmount Decimal?      @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  donations      Donation[]
  program        Program       @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([status])
  @@map("projects")
}

model Donation {
  id                 String              @id @default(cuid())
  userId             String?
  projectId          String?
  amount             Decimal             @db.Decimal(12, 2)
  type               DonationType        @default(GENERAL)
  paymentMethod      PaymentMethod
  status             DonationStatus      @default(PENDING)
  isAnonymous        Boolean             @default(false)
  isRecurring        Boolean             @default(false)
  recurringFrequency RecurringFrequency?
  fullName           String?
  phone              String?
  email              String?
  notes              String?
  receiptNumber      String              @unique
  idempotencyKey     String?             @unique
  internalReference  String              @unique @default(cuid())
  walletPhone        String?
  simulatedPaymentId String?
  paidAt             DateTime?
  refundReason       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  project            Project?            @relation(fields: [projectId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

model Beneficiary {
  id            String          @id @default(cuid())
  name          String
  type          BeneficiaryType @default(FAMILY)
  phone         String?
  nationalId    String?         @unique
  governorate   String?
  address       String?
  notes         String?
  programId     String?
  status        EntityStatus    @default(PENDING)
  monthlyAid    Decimal?        @db.Decimal(10, 2)
  membersCount  Int?
  startDate     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  program       Program?        @relation(fields: [programId], references: [id])
  disbursements Disbursement[]

  @@index([status])
  @@index([programId])
  @@map("beneficiaries")
}

model Disbursement {
  id            String             @id @default(cuid())
  beneficiaryId String
  amount        Decimal            @db.Decimal(12, 2)
  type          String
  status        DisbursementStatus @default(PENDING)
  approvedById  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  approvedBy    User?              @relation("ApprovedBy", fields: [approvedById], references: [id])
  beneficiary   Beneficiary        @relation(fields: [beneficiaryId], references: [id])

  @@index([beneficiaryId])
  @@index([status])
  @@map("disbursements")
}

model Report {
  id            String     @id @default(cuid())
  title         String
  type          ReportType
  period        String
  fileUrl       String?
  generatedById String
  createdAt     DateTime   @default(now())
  generatedBy   User       @relation(fields: [generatedById], references: [id])

  @@map("reports")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model VolunteerApplication {
  id              String          @id @default(cuid())
  name            String
  email           String
  phone           String
  area            VolunteerArea
  message         String?
  status          VolunteerStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  adminNotes      String?
  nextSteps       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reviewedBy      User?           @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("volunteer_applications")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_messages")
}

model SpecialRequest {
  id              String                @id @default(cuid())
  name            String
  email           String
  phone           String
  requestType     String
  description     String
  status          SpecialRequestStatus  @default(PENDING)
  aidType         AidType?
  adminNotes      String?
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  reviewedBy      User?                 @relation("ReviewedSpecialRequests", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([aidType])
  @@index([createdAt])
  @@map("special_requests")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorRole String
  action    String
  entity    String
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Reconciliation {
  id                       String   @id @default(cuid())
  periodStart              DateTime
  periodEnd                DateTime
  totalSystemAmount        Decimal  @db.Decimal(12, 2)
  totalSuccessfulDonations Int
  createdAt                DateTime @default(now())

  @@map("reconciliations")
}

model OrgSettings {
  id                   String   @id @default("singleton")
  name                 String   @default("جمعية نور الخيرية")
  email                String   @default("info@nour-charity.org")
  phone                String   @default("+20 2 1234 5678")
  address              String   @default("القاهرة، مصر")
  language             String   @default("ar")
  timezone             String   @default("Africa/Cairo")
  currency             String   @default("EGP")
  notifyNewDonation    Boolean  @default(true)
  notifyDisbursement   Boolean  @default(true)
  notifyNewBeneficiary Boolean  @default(false)
  notifyWeeklyReport   Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("org_settings")
}

model ChatbotLog {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  reply     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chatbot_logs")
}

model Campaign {
  id          String         @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  goal        Decimal        @db.Decimal(12, 2)
  raised      Decimal        @default(0) @db.Decimal(12, 2)
  donorsCount Int            @default(0)
  status      CampaignStatus @default(ACTIVE)
  startDate   DateTime       @default(now())
  endDate     DateTime?
  featured    Boolean        @default(false)
  category    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([endDate])
  @@map("campaigns")
}

enum UserRole {
  USER
  ADMIN
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum DonationType {
  SADAQAH
  ZAKAT
  ORPHAN_SPONSORSHIP
  SADAQAH_JARIYAH
  GENERAL
}

enum PaymentMethod {
  CARD
  VODAFONE_CASH
  ORANGE_CASH
  INSTAPAY
  FAWRY
  BANK_TRANSFER
}

enum DisbursementStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum BeneficiaryType {
  FAMILY
  INDIVIDUAL
  INSTITUTION
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PENDING
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  UPCOMING
}

enum ReportType {
  DONATIONS
  BENEFICIARIES
  PROJECTS
  FINANCE
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum VolunteerArea {
  MEDICAL
  EDUCATION
  COMMUNITY
  TECH
  ADMIN
  FIELD
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

enum SpecialRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AidType {
  CASH
  MONTHLY_ALLOWANCE
  FINANCIAL_AID
  FOOD
  MEDICAL
  EDUCATIONAL
  OTHER
}
